      "targets": [
        {
          "expr": "increase(twilio_gateway_calls_total[5m])",
          "legendFormat": "Calls (5m)"
        },
        {
          "expr": "increase(twilio_gateway_calls_rejected_total[5m])",
          "legendFormat": "Rejected (5m)"
        }
      ],
      "fieldConfig": {
        "defaults": {
