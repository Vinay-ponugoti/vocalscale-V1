# API Configuration
VITE_API_URL=
VITE_PAYMENT_API_URL=
VITE_KNOWLEDGE_API_URL=

# Analytics & Tracking
# Get your Google Analytics tracking ID from: https://analytics.google.com/
VITE_GA_TRACKING_ID=your-ga-tracking-id-here

# Get your Microsoft Clarity project ID from: https://clarity.microsoft.com/
VITE_CLARITY_PROJECT_ID=your-clarity-project-id-here

# Cloudflare Turnstile CAPTCHA
# Get your site key from: https://dash.cloudflare.com/sign-up
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# Token Encryption (generate a strong random string for production)
# You can generate one with: openssl rand -base64 32
VITE_TOKEN_ENCRYPTION_KEY=$(openssl rand -base64 32)

# CORS & CSP Configuration
VITE_API_ALLOWED_ORIGINS=self 

# Development overrides
# VITE_ALLOW_INTERNET_CONNECT=true
